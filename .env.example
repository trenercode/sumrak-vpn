# compose services use host networking to reach the local Xray API
DATABASE_URL=postgresql+asyncpg://vpn:vpn@127.0.0.1:5432/vpn
BOT_TOKEN=
BOT_USERNAME=
SUPPORT_TELEGRAM_URL=https://t.me/username
PANEL_PUBLIC_URL=https://panel.sumrak.digital
# HTTPS URL Web App. По умолчанию используется PANEL_PUBLIC_URL/webapp
WEBAPP_URL=https://panel.sumrak.digital/webapp
# Только для локальной разработки: разрешает X-Dev-Telegram-Id с этим значением
WEBAPP_DEV_TELEGRAM_ID=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
TRIAL_DAYS=3
MAX_DEVICES=10
BROADCAST_DELAY_SECONDS=0.08

# mock for local development, xray on the VPN server
VPN_BACKEND=mock
XRAY_API_ADDRESS=127.0.0.1:10085
XRAY_INBOUND_TAG=vless-reality
XRAY_CONFIG_PATH=/data/xray/config.json
XRAY_CONTAINER_NAME=vpn-xray
DOCKER_SOCKET_PATH=/var/run/docker.sock
XRAY_PUBLIC_HOST=
XRAY_PUBLIC_PORT=8443
XRAY_REALITY_SERVER_NAME=www.microsoft.com
XRAY_REALITY_PUBLIC_KEY=
XRAY_REALITY_SHORT_ID=
XRAY_FINGERPRINT=chrome
XRAY_FLOW=xtls-rprx-vision
DEFAULT_SERVER_NAME=Sumrak VPN
DEFAULT_SERVER_COUNTRY_CODE=RU
DEFAULT_SERVER_COUNTRY_NAME=Default
DEFAULT_SERVER_CITY=

# Never copy production secrets into this file.
# compose.staging.yaml forces its own isolated PostgreSQL URL and VPN_BACKEND=mock.
DATABASE_URL=postgresql+asyncpg://vpn_test:vpn_test_change_me@db:5432/vpn_test

# Create a separate bot with @BotFather. Never use the production bot token.
BOT_TOKEN=
BOT_USERNAME=sumrak_vpn_test_bot
SUPPORT_TELEGRAM_URL=https://t.me/username

PANEL_PUBLIC_URL=https://test.sumrak.digital
WEBAPP_URL=https://test.sumrak.digital/webapp
WEBAPP_DEV_TELEGRAM_ID=

ADMIN_USERNAME=staging-admin
ADMIN_PASSWORD=change-this-staging-password
TRIAL_DAYS=3
MAX_DEVICES=10
BROADCAST_DELAY_SECONDS=0.08

# Staging intentionally does not mount or restart production Xray.
VPN_BACKEND=mock
XRAY_PUBLIC_HOST=test-node.example.com
XRAY_PUBLIC_PORT=18443
XRAY_REALITY_SERVER_NAME=www.microsoft.com
XRAY_REALITY_PUBLIC_KEY=test-public-key
XRAY_REALITY_SHORT_ID=0123456789abcdef
XRAY_FINGERPRINT=chrome
XRAY_FLOW=xtls-rprx-vision
XRAY_CONTAINER_NAME=sumrak-vpn-test-xray
DEFAULT_SERVER_NAME=Sumrak VPN Staging
DEFAULT_SERVER_COUNTRY_CODE=DE
DEFAULT_SERVER_COUNTRY_NAME=Test
DEFAULT_SERVER_CITY=Staging

# compose services use host networking to reach the local Xray API
DATABASE_URL=postgresql+asyncpg://vpn:vpn@127.0.0.1:5432/vpn
BOT_TOKEN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
TRIAL_DAYS=3
MAX_DEVICES=10

# mock for local development, xray on the VPN server
VPN_BACKEND=mock
XRAY_API_ADDRESS=127.0.0.1:10085
XRAY_INBOUND_TAG=vless-reality
XRAY_CONFIG_PATH=/data/xray/config.json
XRAY_CONTAINER_NAME=vpn-xray
DOCKER_SOCKET_PATH=/var/run/docker.sock
XRAY_PUBLIC_HOST=
XRAY_PUBLIC_PORT=8443
XRAY_REALITY_SERVER_NAME=www.microsoft.com
XRAY_REALITY_PUBLIC_KEY=
XRAY_REALITY_SHORT_ID=
XRAY_FINGERPRINT=chrome

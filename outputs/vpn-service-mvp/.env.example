# compose services use host networking so they can control the host WireGuard interface
DATABASE_URL=postgresql+asyncpg://vpn:vpn@127.0.0.1:5432/vpn
BOT_TOKEN=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
TRIAL_DAYS=3
MAX_DEVICES=10

# mock for local development, wireguard on the VPN server
VPN_BACKEND=mock
WG_INTERFACE=wg0
WG_SERVER_PUBLIC_KEY=
WG_ENDPOINT=vpn.example.com:51820
WG_NETWORK=10.66.0.0/24
WG_SERVER_ADDRESS=10.66.0.1
WG_DNS=1.1.1.1,1.0.0.1
WG_PERSISTENT_KEEPALIVE=25
